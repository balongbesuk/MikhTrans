<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- App Logo & Header -->
        <TextView
            android:id="@+id/app_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MikhPay"
            android:textColor="#10b981"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginTop="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Automatic QRIS Notification Forwarder"
            android:textColor="#888888"
            android:textSize="14sp"
            android:layout_gravity="center"
            android:layout_marginBottom="30dp" />

        <!-- Status Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#1e1e1e"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="System Status"
                    android:textColor="#ffffff"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <View
                        android:id="@+id/status_dot"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/circle_red"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/status_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Notification Access Disabled"
                        android:textColor="#ff5252"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <Button
                    android:id="@+id/btn_grant_permission"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Grant Access Permission"
                    android:textAllCaps="false"
                    android:textColor="#ffffff"
                    android:backgroundTint="#10b981"
                    app:cornerRadius="12dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Configuration Form -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#1e1e1e"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Configuration"
                    android:textColor="#ffffff"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="20dp"/>

                <!-- Webhook URL -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Webhook URL"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/input_webhook_url"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/edittext_background"
                    android:inputType="textUri"
                    android:textColor="#ffffff"
                    android:paddingHorizontal="16dp"
                    android:hint="https://yourdomain.com/qris_verify.php"
                    android:textColorHint="#444444"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp"/>

                <!-- API Key -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="API Key (Token)"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/input_api_key"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/edittext_background"
                    android:inputType="textPassword"
                    android:textColor="#ffffff"
                    android:paddingHorizontal="16dp"
                    android:hint="Enter MikhPay API Secret Key"
                    android:textColorHint="#444444"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp"/>

                <!-- Package Whitelist -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Target Apps Whitelist"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/input_package_whitelist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="80dp"
                    android:gravity="top"
                    android:background="@drawable/edittext_background"
                    android:inputType="textMultiLine"
                    android:textColor="#ffffff"
                    android:padding="16dp"
                    android:hint="com.sg.gobiz, com.dana, com.ovo.id"
                    android:textColorHint="#444444"
                    android:textSize="14sp"
                    android:layout_marginBottom="24dp"/>

                <!-- Save & Test Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btn_save"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:text="Save Settings"
                        android:textAllCaps="false"
                        android:textColor="#ffffff"
                        android:backgroundTint="#10b981"
                        android:layout_marginEnd="6dp"
                        app:cornerRadius="12dp" />

                    <Button
                        android:id="@+id/btn_test"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:text="Test Webhook"
                        android:textAllCaps="false"
                        android:textColor="#10b981"
                        android:backgroundTint="#1a10b981"
                        android:layout_marginStart="6dp"
                        app:cornerRadius="12dp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>
