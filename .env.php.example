<?php header('HTTP/1.0 403 Forbidden'); exit; ?>
# ==============================================================================
# BERKAS CONTOH KONFIGURASI LINGKUNGAN (.env.php.example)
# Salin berkas ini menjadi '.env.php' di root folder dan sesuaikan nilainya.
# ==============================================================================

# API Key untuk mengamankan REST API (api.php)
# Digunakan untuk otentikasi saat sistem eksternal mengakses data MikhPay Anda.
MIKHMON_API_KEY="mikhmon_api_key_12345"

# Kredensial QRIS Mandiri (Ganti dengan string hasil scan QR statis Anda)
# Untuk membaca string QRIS, gunakan pemindai barcode/QR dari HP Anda.
QRIS_MODE=true
QRIS_STATIC_STRING="00020101021126670016COM.GO-JEK.WWW0118...YOUR_QRIS_STRING..."

# Token Rahasia untuk Endpoint Verifikasi QRIS Mandiri (MacroDroid/Webhook)
# Buatlah string acak sebagai pengaman (password) agar endpoint tidak disalahgunakan.
QRIS_SECRET_TOKEN="ganti_dengan_token_rahasia_anda_123"

# App ID Pusher / Soketi (ID Aplikasi WebSocket)
# Didapatkan dari Dashboard Pusher -> App Keys. Kosongkan untuk menonaktifkan WebSocket.
WS_APP_ID="YOUR_PUSHER_APP_ID"

# App Key Pusher / Soketi (Kunci Publik WebSocket)
# Didapatkan dari Dashboard Pusher -> App Keys. Digunakan di browser untuk terhubung ke socket.
WS_APP_KEY="YOUR_PUSHER_KEY"

# App Secret Pusher / Soketi (Kunci Rahasia WebSocket)
# Didapatkan dari Dashboard Pusher -> App Keys. Digunakan di backend untuk memicu event lunas.
WS_APP_SECRET="YOUR_PUSHER_SECRET"

# Cluster Server Pusher
# Didapatkan dari Dashboard Pusher (contoh: 'ap1' untuk wilayah Asia Tenggara / Singapura).
WS_CLUSTER="ap1"

# Host Kustom Server WebSocket (Soketi / Self-Hosted)
# Masukkan domain server Soketi Anda (contoh: 'soketi.domainanda.com').
# Kosongkan jika Anda memilih menggunakan server Cloud Pusher resmi.
# WS_HOST=""

# Port Kustom Server WebSocket (Soketi / Self-Hosted)
# Masukkan port server Soketi Anda (contoh: '6001' untuk http atau '443' untuk https).
# Kosongkan jika Anda memilih menggunakan server Cloud Pusher resmi.
# WS_PORT=""

# Protokol Kustom Server WebSocket (Soketi / Self-Hosted)
# Masukkan protokol server Soketi Anda ('http', 'https', 'ws', atau 'wss').
# Kosongkan jika Anda memilih menggunakan server Cloud Pusher resmi.
# WS_SCHEME=""

# Kunci Enkripsi Kredensial MikroTik (AES-256-CBC)
# Silakan ganti dengan string acak panjang untuk keamanan maksimal.
ENCRYPTION_KEY="mikhmon_secure_key_placeholder"
